---
/**
 * Footer override — renders the default Starlight Footer plus a
 * "docs current as of X.Y.Z" freshness line (FR-018 / T010).
 *
 * Version detection (Phase 7 per-version build model):
 *   Primary:  BASE_URL (set per build via PP_DOCS_BASE) — e.g. "/v0.1/" or "/next/".
 *   Fallback: URL path (legacy dynamic-route /v/X.Y/... for dev/single-build compat).
 *
 *   - "/v0.1/" build → look up minor "0.1" in manifest → show lastPatch.
 *   - "/next/"  build → show "next (main)" label.
 *   - dev/bare-path  → show the isLatest entry's label.
 */
import DefaultFooter from "@astrojs/starlight/components/Footer.astro";
import versionsData from "../../data/versions.json";

// BASE_URL is the Astro built-in, set per build (e.g. "/v0.1/" or "/next/").
const buildBase = import.meta.env.BASE_URL?.replace(/\/$/, "") ?? "";

// Derive current minor from the build base (per-version builds).
const baseMinorMatch = buildBase.match(/^\/v(\d+\.\d+)$/);
const isNextBuild    = buildBase === "/next";

let freshnessLabel = "";

if (baseMinorMatch) {
  // Released minor build (e.g. base="/v0.1/").
  const minor = baseMinorMatch[1];
  const entry = versionsData.versions.find((v) => v.minor === minor);
  freshnessLabel = entry ? entry.lastPatch : minor;
} else if (isNextBuild) {
  // next build.
  freshnessLabel = "next (main)";
} else {
  // Dev / single-build fallback: also try path-based detection for legacy compat.
  const pathname = Astro.url.pathname;
  const legacyMatch = pathname.match(/\/v\/([^/]+)/);
  if (legacyMatch) {
    const minor = legacyMatch[1];
    const entry = versionsData.versions.find((v) => v.minor === minor);
    freshnessLabel = entry ? entry.lastPatch : minor;
  } else {
    // Latest/bare path: show the isLatest entry's label.
    const latestEntry = versionsData.versions.find((v) => v.isLatest);
    freshnessLabel = latestEntry ? latestEntry.label : versionsData.latest;
  }
}
---

<DefaultFooter {...Astro.props}>
  <slot />
</DefaultFooter>

{freshnessLabel && (
  <p class="docs-freshness">
    docs current as of <strong>{freshnessLabel}</strong>
  </p>
)}

<style>
  .docs-freshness {
    font-size: var(--sl-text-xs, 0.75rem);
    color: var(--sl-color-gray-3, #9ca3af);
    margin-top: 0.5rem;
    text-align: center;
  }
</style>
