---
/**
 * VersionSelect.astro
 *
 * TC04: Version dropdown for the per-version whole-site build model (Phase 7).
 *
 * URL scheme (per-version builds):
 *   /next/…         — the working-tree "next" build
 *   /v0.1/…         — a released minor build
 *   /v{latest}/…    — the latest released build (same prefix scheme)
 *
 * hrefFor logic:
 *   - link to /{targetPrefix}/{currentSlug}/ when slug is in that version's
 *     slugs[], else degrade to /{targetPrefix}/ (FR-003).
 *   - All entries use explicit prefixes — no bare-path / isLatest collapse.
 *   - Dropdown is baked from the CURRENT manifest in every build (rebuild-all
 *     every deploy), so older version pages list newer versions released later.
 *
 * Current version is highlighted; newest released first, then `next` last.
 */

import versionsData from "../data/versions.json";

// BASE_URL is the Astro built-in, set per build (e.g. "/v0.1/" or "/next/").
// Strip trailing slash for clean concatenation.
const buildBase = import.meta.env.BASE_URL?.replace(/\/$/, "") ?? "";

// Determine the version prefix this page lives under.
// buildBase is e.g. "/v0.1" or "/next" for per-version builds.
// We derive the prefix from buildBase for the "current" highlight.
// - "/v0.1" → minor = "0.1"
// - "/next"  → minor = "next"
// - "/"      → dev/single-build, fall back to isLatest detection
const baseMinorMatch = buildBase.match(/^\/v(\d+\.\d+)$/);
const isNextBuild    = buildBase === "/next";
const currentMinor   = baseMinorMatch
  ? baseMinorMatch[1]
  : isNextBuild
    ? "next"
    : null; // null = dev/single-build, fall back below

// In dev/single-build mode, also try to derive from the current page URL
// (legacy path /v/X.Y/... from the old dynamic route, if still present).
const pathname = Astro.url.pathname;
let resolvedCurrentMinor = currentMinor;
if (resolvedCurrentMinor === null) {
  const legacyMatch = pathname.match(/\/v\/([^/]+)/);
  resolvedCurrentMinor = legacyMatch ? legacyMatch[1] : null;
}

// Extract the current slug from the URL for best-effort slug preservation.
// For per-version builds: strip the build base prefix.
// e.g. /v0.1/reference/rust/ → "reference/rust"
//      /next/reference/rust/ → "reference/rust"
//      /         → ""  (index)
let currentSlug = pathname
  .replace(new RegExp(`^${buildBase}/?`), "")
  .replace(/\/$/, "")
  .replace(/^\//, "");

// Normalise: "index" → ""
if (currentSlug === "index") currentSlug = "";

const versions = versionsData.versions;

/**
 * Return the href for a given version entry.
 *
 * TC04: every version has an explicit prefix:
 *   - released minor vX.Y  → /vX.Y/
 *   - next                 → /next/
 *
 * Link to /{prefix}/{currentSlug}/ when the slug exists in that version's
 * slugs[], else degrade to /{prefix}/ (FR-003 graceful degradation).
 *
 * @param {object} entry  — a versions.json version entry
 * @returns {string}      — absolute href (no base repetition; base is baked in)
 */
function hrefFor(entry) {
  const prefix = entry.minor === "next" ? "/next" : `/v${entry.minor}`;

  // Check whether the current slug exists in this version.
  const slugExists =
    currentSlug === "" ||
    (Array.isArray(entry.slugs) && entry.slugs.includes(currentSlug));

  if (slugExists && currentSlug !== "") {
    return `${prefix}/${currentSlug}/`;
  }
  return `${prefix}/`;
}

// Determine the active (currently-displayed) version for the dropdown highlight.
const activeEntry = versions.find(
  (v) =>
    v.minor === resolvedCurrentMinor ||
    (resolvedCurrentMinor === null && v.isLatest),
);
const activeLabel = activeEntry?.label ?? (resolvedCurrentMinor ?? "docs");
---

<div class="version-select-wrapper">
  <label for="version-select" class="sr-only">Select documentation version</label>
  <select
    id="version-select"
    class="version-select"
    onchange="window.location.href = this.value"
    aria-label="Select documentation version"
  >
    {versions.map((entry) => {
      const href = hrefFor(entry);
      const isActive =
        entry.minor === resolvedCurrentMinor ||
        (resolvedCurrentMinor === null && entry.isLatest);
      return (
        <option value={href} selected={isActive}>
          {entry.label}
        </option>
      );
    })}
  </select>
</div>

<style>
  .version-select-wrapper {
    display: inline-flex;
    align-items: center;
    margin-inline-start: 0.75rem;
  }
  .version-select {
    font-size: var(--sl-text-sm, 0.875rem);
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--sl-color-gray-5, #ccc);
    border-radius: 4px;
    background: var(--sl-color-bg, #fff);
    color: var(--sl-color-text, inherit);
    cursor: pointer;
    max-width: 12rem;
  }
  .version-select:hover,
  .version-select:focus {
    border-color: var(--sl-color-accent, #888);
    outline: none;
  }
  /* Hide on print */
  @media print {
    .version-select-wrapper { display: none; }
  }
</style>
