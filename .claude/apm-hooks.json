{
  "PreToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-package-version/scripts/package-file-warn.sh",
          "if": "Edit(Cargo.toml)|Edit(package.json)|Edit(pyproject.toml)|Edit(go.mod)|Edit(Gemfile)|Edit(composer.json)|Write(Cargo.toml)|Write(package.json)|Write(pyproject.toml)|Write(go.mod)|Write(Gemfile)|Write(composer.json)"
        }
      ],
      "_apm_source": "mcp-package-version"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-package-version/scripts/pkg-version-warn.sh",
          "if": "Bash(pnpm add*)|Bash(cargo add*)|Bash(uv add*)|Bash(pip install*)"
        }
      ],
      "_apm_source": "mcp-package-version"
    },
    {
      "matcher": "Grep|Glob|Read",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/code-intelligence/scripts/code-discovery-steer.sh",
          "timeout": 3
        }
      ],
      "_apm_source": "code-intelligence"
    },
    {
      "matcher": "apply_patch|Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/agent-coder/scripts/coder-delegation-reminder.sh",
          "timeout": 3
        }
      ],
      "_apm_source": "agent-coder"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/hooks-bash-safety/scripts/bash-guard.sh"
        },
        {
          "type": "command",
          "command": ".claude/hooks/hooks-bash-safety/scripts/rm-rf-guard.sh"
        }
      ],
      "_apm_source": "hooks-bash-safety"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/hooks-git-safety/scripts/git-guard.sh"
        }
      ],
      "_apm_source": "hooks-git-safety"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-context7-reminder.sh"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-issue-close-guard.sh"
        },
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-issue-label-guard.sh"
        },
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-pr-issue-refs.sh"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/dispatcher.py ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/nodes.json pre",
          "timeout": 5,
          "statusMessage": "Checking SpecKit DAG preconditions..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/code-intelligence/scripts/reindex-after-commit.sh",
          "if": "Bash(git commit*)",
          "async": true,
          "timeout": 30
        }
      ],
      "_apm_source": "code-intelligence"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git switch -c*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git switch --create*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git checkout -b*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git checkout -B*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git worktree add*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git merge*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git pull*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "async": true,
          "timeout": 30,
          "if": "Bash(git rebase*)"
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-task-commit-check.sh",
          "if": "Bash(git commit*)"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/dispatcher.py ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/nodes.json post",
          "timeout": 5,
          "statusMessage": "Loading SpecKit next-step context..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-deferred-issues.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-stop-gate.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ],
  "UserPromptExpansion": [
    {
      "matcher": "speckit.*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/dispatcher.py ${CLAUDE_PROJECT_DIR}/.claude/hooks/speckit-dag-hooks/scripts/nodes.json pre",
          "timeout": 5,
          "statusMessage": "Checking SpecKit DAG preconditions..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "SessionStart": [
    {
      "matcher": "startup",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/code-intelligence/scripts/codebase-index.sh",
          "async": true,
          "statusMessage": "Indexing codebase..."
        }
      ],
      "_apm_source": "code-intelligence"
    }
  ],
  "SubagentStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/code-intelligence/scripts/subagent-context-inject.sh",
          "timeout": 5
        }
      ],
      "_apm_source": "code-intelligence"
    }
  ]
}
